-- 1. Bảng Người dùng (Lưu tài khoản khách hàng)
CREATE TABLE NguoiDung (
    id INT IDENTITY(1,1) PRIMARY KEY,
    hoTen NVARCHAR(100) NOT NULL,
    email VARCHAR(100) UNIQUE NOT NULL,
    matKhau VARCHAR(255) NOT NULL, -- Lưu chữ thuần như bạn muốn
    soDienThoai VARCHAR(15),
    diaChi NVARCHAR(MAX),
    vaiTro VARCHAR(20) DEFAULT 'khach_hang',
    ngayTao DATETIME DEFAULT GETDATE()
);

-- 2. Bảng Sản phẩm (Kho cây cảnh)
CREATE TABLE SanPham (
    id INT IDENTITY(1,1) PRIMARY KEY,
    tenCay NVARCHAR(255) NOT NULL,
    gia DECIMAL(10,2) NOT NULL,
    loai VARCHAR(50) NOT NULL, -- trong-nha, sen-da, ngoai-troi
    anh VARCHAR(255),
    doAmLyTuong INT,           -- Chỉ số để AI so sánh
    moTa NVARCHAR(MAX)
);

-- 3. Bảng Đơn hàng (Lưu thông tin khi khách bấm mua)
CREATE TABLE DonHang (
    id INT IDENTITY(1,1) PRIMARY KEY,
    nguoiDungId INT,
    tenNguoiNhan NVARCHAR(100),
    soDienThoaiNhan VARCHAR(15),
    diaChiGiaoHang NVARCHAR(MAX),
    tongTien DECIMAL(10,2),
    ngayDat DATETIME DEFAULT GETDATE(),
    trangThai NVARCHAR(50) DEFAULT N'Chờ xác nhận',
    FOREIGN KEY (nguoiDungId) REFERENCES NguoiDung(id)
);

-- 4. Bảng Lịch chăm sóc (Dành cho tính năng AI nhắc tưới cây)
CREATE TABLE LichChamsoc (
    id INT IDENTITY(1,1) PRIMARY KEY,
    nguoiDungId INT,
    sanPhamId INT,
    ngayTuoiGanNhat DATE,
    ghiChuAI NVARCHAR(MAX),
    FOREIGN KEY (nguoiDungId) REFERENCES NguoiDung(id),
    FOREIGN KEY (sanPhamId) REFERENCES SanPham(id)
);
